# PostSocial — Variáveis de Ambiente
# Copie para .env e preencha com seus valores

# Chave secreta do Flask (gere uma aleatória)
SECRET_KEY=troque-por-uma-chave-segura

# Chave de criptografia para senhas do Instagram (NÃO mude depois de salvar senhas)
# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# IA para legendas (Groq — gratuito e rápido)
GROQ_API_KEY=

# Meta / Instagram — conexão oficial (OAuth)
# Crie um app em developers.facebook.com, produto «Facebook Login», URIs de redirecionamento OAuth válidos:
#   https://SEU_DOMINIO/instagram/oauth/callback
META_APP_ID=
META_APP_SECRET=
# Opcional — deve coincidir com o configurado no app Meta (padrão: postay callback)
# META_OAUTH_REDIRECT_URI=https://postay.com.br/instagram/oauth/callback

# URL pública do site (para montar image_url na API Graph ao publicar)
PUBLIC_BASE_URL=https://postay.com.br

# Meta Pixel (PageView + eventos)
META_PIXEL_ID=1004046572371964

# TikTok — Login Kit + Content Posting (https://developers.tiktok.com/)
# Redirect URI no portal deve ser EXATAMENTE a mesma (HTTPS, sem query/hash):
#   https://postay.com.br/tiktok/callback
# TikTok OAuth — APP_BASE_URL e TIKTOK_REDIRECT_URI devem bater com Login Kit no portal (sem barra extra no final).
# Ex.: TIKTOK_REDIRECT_URI=https://postay.com.br/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=https://postay.com.br/tiktok/callback
# Após ativar os escopos no app, pode usar por ex.:
# TIKTOK_OAUTH_SCOPES=user.info.basic,video.publish,video.upload

# Pagamentos — Mercado Pago + PIX manual
# Portal: https://www.mercadopago.com.br/developers — Login Kit / Checkout Pro
# Redirect / webhook: APP_BASE_URL deve ser https://postay.com.br em produção
APP_BASE_URL=https://postay.com.br
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PIX_KEY=fabianosf@gmail.com
PIX_MERCHANT_NAME=Postay
PIX_MERCHANT_CITY=SaoPaulo
PRO_PRICE=99.90
AGENCY_PRICE=249.00

# Email (opcional — notificações)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@email.com
# SMTP_PASS=sua-senha-de-app
